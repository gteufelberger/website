{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "strictNullChecks": true,
    "paths": {
      "$lib/*": ["./src/lib/*"],
      "$components/*": ["./src/components/*"],
      "$layouts/*": ["./src/layouts/*"],
      "$pages/*": ["./src/pages/*"],
      "$styles/*": ["./src/styles/*"],
      "$assets/*": ["./src/assets/*"],
      "$examples/*": ["./src/examples/*"],
      "$content/*": ["./src/content/*"]
    }
  },
  "exclude": ["public/pagefind", "dist"]
}
